{
  "name": "blog-platform",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "prisma db push --skip-generate && npx ts-node --project tsconfig.node.json prisma/ensure-admin.ts && next dev",
    "build": "prisma generate && next build",
    "start": "next start -p 3010",
    "prod:prepare": "prisma db push --skip-generate && npx ts-node --project tsconfig.node.json prisma/ensure-admin.ts",
    "deploy": "npm run prod:prepare && npm run build",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:seed": "npx ts-node --project tsconfig.node.json prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@tiptap/core": "^2.10.4",
    "@tiptap/extension-blockquote": "^2.10.4",
    "@tiptap/extension-bold": "^2.10.4",
    "@tiptap/extension-bullet-list": "^2.10.4",
    "@tiptap/extension-code": "^2.10.4",
    "@tiptap/extension-code-block": "^2.10.4",
    "@tiptap/extension-document": "^2.10.4",
    "@tiptap/extension-dropcursor": "^2.10.4",
    "@tiptap/extension-gapcursor": "^2.10.4",
    "@tiptap/extension-hard-break": "^2.10.4",
    "@tiptap/extension-heading": "^2.10.4",
    "@tiptap/extension-history": "^2.10.4",
    "@tiptap/extension-horizontal-rule": "^2.10.4",
    "@tiptap/extension-image": "^2.10.4",
    "@tiptap/extension-italic": "^2.10.4",
    "@tiptap/extension-link": "^2.10.4",
    "@tiptap/extension-list-item": "^2.10.4",
    "@tiptap/extension-ordered-list": "^2.10.4",
    "@tiptap/extension-paragraph": "^2.10.4",
    "@tiptap/extension-placeholder": "^2.10.4",
    "@tiptap/extension-strike": "^2.10.4",
    "@tiptap/extension-text": "^2.10.4",
    "@tiptap/extension-underline": "^2.10.4",
    "@tiptap/react": "^2.10.4",
    "@tiptap/starter-kit": "^2.10.4",
    "bcryptjs": "^2.4.3",
    "iron-session": "^8.0.4",
    "lucide-react": "^0.454.0",
    "next": "^15.1.6",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sanitize-html": "^2.13.1",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.15",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/sanitize-html": "^2.13.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
